# AgentPoppy production example.
# Do not commit real secrets. Copy into your hosting provider's secret store.
# Replace https://agentpoppy.example.com with the real production origin.

NODE_ENV=production
HOST=0.0.0.0
PORT=3001
AGENT_POPPY_DATA_DIR=/var/lib/agent-poppy/data
AGENT_POPPY_WEB_DIST=apps/web/dist

# Public website/API origin used in install commands and OAuth redirects.
AGENT_POPPY_PUBLIC_API_BASE_URL=https://agentpoppy.example.com
AGENT_POPPY_CORS_ORIGINS=https://agentpoppy.example.com

# Google OAuth Web Client.
# Google Console authorized redirect URI:
#   https://agentpoppy.example.com/api/auth/google/callback
AGENT_POPPY_GOOGLE_CLIENT_ID=
AGENT_POPPY_GOOGLE_CLIENT_SECRET=
AGENT_POPPY_GOOGLE_REDIRECT_URI=https://agentpoppy.example.com/api/auth/google/callback
AGENT_POPPY_ENABLE_DEV_PORTAL_LOGIN=false
AGENT_POPPY_PORTAL_SESSION_DAYS=30

# Product API key issuer. Use a long random production-only secret.
AGENT_POPPY_KEY_ISSUER_SECRET=

# Optional admin key for admin-only Product API key tools.
AGENT_POPPY_ADMIN_KEY=

# Developer Preview defaults: unlimited for now, configurable later.
AGENT_POPPY_QUOTAS=character_randomize=unlimited,room_create=unlimited,template_read=unlimited,template_apply=unlimited,bridge_prompt=unlimited
