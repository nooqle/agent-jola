# Agent Jola production example for agentjola.tech.
# Do not commit real secrets. Copy into your hosting provider's secret store.

NODE_ENV=production
HOST=0.0.0.0
PORT=3001
AGENT_BOMBER_DATA_DIR=/var/lib/agent-jola/data
AGENT_JOLA_WEB_DIST=apps/web/dist

# Public website/API origin used in install commands and OAuth redirects.
AGENT_JOLA_PUBLIC_API_BASE_URL=https://agentjola.tech
AGENT_JOLA_CORS_ORIGINS=https://agentjola.tech,https://www.agentjola.tech

# Google OAuth Web Client.
# Google Console authorized redirect URI:
#   https://agentjola.tech/api/auth/google/callback
AGENT_JOLA_GOOGLE_CLIENT_ID=
AGENT_JOLA_GOOGLE_CLIENT_SECRET=
AGENT_JOLA_GOOGLE_REDIRECT_URI=https://agentjola.tech/api/auth/google/callback
AGENT_JOLA_ENABLE_DEV_PORTAL_LOGIN=false
AGENT_JOLA_PORTAL_SESSION_DAYS=30

# Product API key issuer. Use a long random production-only secret.
AGENT_JOLA_KEY_ISSUER_SECRET=

# Optional admin key for admin-only Product API key tools.
AGENT_JOLA_ADMIN_KEY=

# Developer Preview defaults: unlimited for now, configurable later.
AGENT_JOLA_QUOTAS=character_randomize=unlimited,room_create=unlimited,template_read=unlimited,template_apply=unlimited,bridge_prompt=unlimited
