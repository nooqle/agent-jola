# Agent Jola local server
HOST=0.0.0.0
PORT=3001
AGENT_BOMBER_DATA_DIR=data
AGENT_JOLA_WEB_DIST=apps/web/dist

# Product API key used by local Agent clients.
# The dev server also accepts this default key when NODE_ENV is not production.
AGENT_JOLA_API_KEY=agent-jola-local-dev-key
AGENT_JOLA_ADMIN_KEY=agent-jola-local-admin-key
AGENT_JOLA_KEY_ISSUER_SECRET=replace-with-a-long-random-local-secret
AGENT_JOLA_PUBLIC_API_BASE_URL=http://127.0.0.1:3001
AGENT_JOLA_CORS_ORIGINS=https://agentjola.tech,https://www.agentjola.tech

# Hosted Portal auth.
AGENT_JOLA_GOOGLE_CLIENT_ID=
AGENT_JOLA_GOOGLE_CLIENT_SECRET=
AGENT_JOLA_GOOGLE_REDIRECT_URI=http://127.0.0.1:3001/api/auth/google/callback
AGENT_JOLA_ENABLE_DEV_PORTAL_LOGIN=false
AGENT_JOLA_PORTAL_SESSION_DAYS=30

# Reported quota policy. "unlimited" keeps the current Developer Preview behavior.
AGENT_JOLA_QUOTAS=character_randomize=unlimited,room_create=unlimited,template_read=unlimited,template_apply=unlimited,bridge_prompt=unlimited

# Local Agent client
AGENT_JOLA_BASE_URL=http://127.0.0.1:3001
AGENT_JOLA_CLOUD_BASE_URL=http://127.0.0.1:3001
AGENT_JOLA_AGENT_NAME=Ember
AGENT_JOLA_MAX_POLLS=240
AGENT_JOLA_POLL_MS=150

# Optional OpenAI bridge client. These stay local and are never uploaded to Agent Jola.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_BASE_URL=https://api.openai.com/v1/responses

# Optional Anthropic bridge client. These stay local and are never uploaded to Agent Jola.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01

# Legacy aliases accepted for one compatibility version:
# AGENT_POPPY_API_KEY, AGENT_POPPY_ADMIN_KEY, AGENT_POPPY_KEY_ISSUER_SECRET,
# AGENT_POPPY_PUBLIC_API_BASE_URL, AGENT_POPPY_BASE_URL, AGENT_POPPY_CLOUD_BASE_URL.
