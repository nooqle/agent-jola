# AgentPoppy local server
HOST=0.0.0.0
PORT=3001
AGENT_POPPY_DATA_DIR=data
AGENT_POPPY_WEB_DIST=apps/web/dist

# Product API key used by local Agent clients.
# The dev server also accepts this default key when NODE_ENV is not production.
AGENT_POPPY_API_KEY=agent-poppy-local-dev-key
AGENT_POPPY_ADMIN_KEY=agent-poppy-local-admin-key
AGENT_POPPY_KEY_ISSUER_SECRET=replace-with-a-long-random-local-secret
AGENT_POPPY_PUBLIC_API_BASE_URL=http://127.0.0.1:3001
AGENT_POPPY_CORS_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# Hosted Portal auth.
# Leave Google credentials empty for normal local-only room development.
AGENT_POPPY_GOOGLE_CLIENT_ID=
AGENT_POPPY_GOOGLE_CLIENT_SECRET=
AGENT_POPPY_GOOGLE_REDIRECT_URI=http://127.0.0.1:3001/api/auth/google/callback
AGENT_POPPY_ENABLE_DEV_PORTAL_LOGIN=false
AGENT_POPPY_PORTAL_SESSION_DAYS=30

# Reported quota policy. "unlimited" keeps the current Developer Preview behavior.
AGENT_POPPY_QUOTAS=character_randomize=unlimited,room_create=unlimited,template_read=unlimited,template_apply=unlimited,bridge_prompt=unlimited

# Local Agent client
AGENT_POPPY_BASE_URL=http://127.0.0.1:3001
AGENT_POPPY_CLOUD_BASE_URL=http://127.0.0.1:3001
AGENT_POPPY_AGENT_NAME=Poppy
AGENT_POPPY_MAX_POLLS=240
AGENT_POPPY_POLL_MS=150

# Optional OpenAI bridge client. These stay local and are never uploaded to AgentPoppy.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_BASE_URL=https://api.openai.com/v1/responses

# Optional Anthropic bridge client. These stay local and are never uploaded to AgentPoppy.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01
